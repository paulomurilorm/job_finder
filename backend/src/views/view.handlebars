<div id="job-view-container" class="container">
  <div class="col-12 text-start mb-4">
    <a class="back-link main-color" href="/">Voltar</a>
  </div>
  <div class="row text-center">
    <div id="img-container" class="col-md-12">
      <img src="/img/computer-worker.png" alt="Company" />
    </div>
    <div class="col-md-12">
      <h1 class="main-color">{{job.dataValues.title}}</h1>
      <p class="bold">Quem eles estão buscando:</p>
      <p class="job-desc">{{job.dataValues.description}}</p>
      <p class="main-color"><span class="bold">O salário informado é de:</span>
        <span class="simple-text">R$</span>{{job.dataValues.salary}}</p>
      <p class="simple-text">Para trabalhar na
        <span class="bold main-color">{{job.dataValues.company}}</span>
        envie um e-mail para a
        <a
          class="main-color"
          href="mail:to{{job.dataValues.email}}"
        >{{job.dataValues.email}}</a></p>
    </div>
  </div>
</div>